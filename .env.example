# Base URL of your APIM "Azure OpenAI v1" route (without the trailing /chat/completions).
APIM_BASE_URL=

# Model / deployment name configured in your Foundry instance.
MODEL=gpt-4o

# Optional. APIM has auth disabled, so this is just a placeholder the SDK requires.
# Set it only if you later enable a subscription key or token.
API_KEY=unused

# Optional. Set this if your APIM gateway still enforces a subscription key.
# Sent as the Ocp-Apim-Subscription-Key header. Leave blank when keys are disabled.
APIM_SUBSCRIPTION_KEY=
